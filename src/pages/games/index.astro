---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { externalGames } from "@/data/externalGames";
import { mainGame } from "@/data/mainGame";
import { siteConfig } from "@/data/siteConfig";

const gamesStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Jeux comme Royal Match",
    itemListElement: externalGames.map((game, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: game.title,
      url: new URL(`/games/${game.slug}/`, siteConfig.siteUrl).href,
    })),
  },
];
---

<BaseLayout
  title="Jeux comme Royal Match"
  description="Jouez a des jeux comme Royal Match: match-3, tuiles, tri de couleurs et puzzles gratuits selectionnes pour les fans de combos."
  structuredData={gamesStructuredData}
>
  <section class="listing-shell">
    <header class="listing-header">
      <p class="eyebrow">Alternatives match-3</p>
      <h1>Jeux comme Royal Match.</h1>
      <p>Vous cherchez une alternative a Royal Match ou un jeu match-3 gratuit a lancer sans telechargement ? Cette page regroupe des jeux Playgama proches: joyaux, couleurs, tuiles, tri et logique de plateau. royalmatch.fr reste un site independant; Royal Match est une marque de Dream Games.</p>
      <div class="hero-actions">
        <a class="primary-action" href="/play/"><span class="play-triangle"></span>Jouer a {mainGame.name}</a>
        <a class="secondary-action" href="/categories/">Parcourir les categories</a>
      </div>
    </header>

    <div class="game-bento-grid" aria-label="Jeux Playgama similaires">
      {externalGames.map((game, index) => (
        <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={`/games/${game.slug}/`}>
          <img src={game.thumbnail} alt={`Miniature ${game.title}`} width="640" height="360" loading={index < 2 ? "eager" : "lazy"} />
          <div>
            <span>{game.category}</span>
            <strong>{game.shortTitle}</strong>
          </div>
        </a>
      ))}
    </div>

    <section class="seo-copy-section" aria-labelledby="games-guide-title">
      <div class="section-head">
        <p class="eyebrow">Selection</p>
        <h2 id="games-guide-title">Pourquoi ces jeux conviennent aux joueurs de Royal Match.</h2>
      </div>
      <div class="seo-copy-grid">
        <article class="seo-copy-card seo-copy-wide">
          <h3>Meme lecture de plateau</h3>
          <p>Les bons jeux comme Royal Match demandent de reconnaitre les couleurs, preparer le prochain mouvement, declencher des cascades et choisir les associations qui ouvrent le plateau. C'est cette boucle de match-3 que la selection privilegie.</p>
        </article>
        <article class="seo-copy-card">
          <h3>Alternatives directes</h3>
          <p>Les jeux de joyaux ou bonbons sont les plus proches si vous voulez garder le rythme des echanges, des combos et des boosters.</p>
        </article>
        <article class="seo-copy-card">
          <h3>Puzzles plus calmes</h3>
          <p>Les jeux de tri, tuiles et mahjong conviennent quand vous voulez une pause plus posee apres un niveau difficile.</p>
        </article>
      </div>
    </section>
  </section>
</BaseLayout>
