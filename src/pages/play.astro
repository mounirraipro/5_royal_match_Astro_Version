---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { externalGames } from "@/data/externalGames";
import { mainGame } from "@/data/mainGame";

const leftGames = externalGames.slice(0, 4);
const rightGames = externalGames.slice(4, 8);
const guideItems = [
  {
    id: "royal-match-rules",
    label: "Règles",
    title: "Alignez trois joyaux",
    body: "Échangez deux pièces voisines pour créer une ligne ou une colonne de trois joyaux identiques.",
  },
  {
    id: "royal-match-bonus",
    label: "Bonus",
    title: "Préparez les gros coups",
    body: "Les associations de quatre ou cinq pièces donnent des bonus qui nettoient des lignes, zones ou couleurs entières.",
  },
  {
    id: "royal-match-mobile",
    label: "Mobile",
    title: "Jouez avec des gestes courts",
    body: "Sur téléphone, utilisez des mouvements précis et attendez la fin des animations avant de choisir le coup suivant.",
  },
];
---

<BaseLayout
  title={`Jouer à ${mainGame.name}`}
  description="Jouez à Royal Match en ligne gratuitement avec un iframe Playgama, des jeux similaires et des conseils de match-3."
>
  <section class="embedded-game-page accent-blue">
    <header class="embedded-game-head">
      <nav class="crumbs"><a href="/">Accueil</a><span>/</span><span>Jouer</span></nav>
      <h1>Jouer à Royal Match en ligne.</h1>
      <p>{mainGame.description}</p>
    </header>

    <div class="embedded-game-layout">
      <div class="game-bento-grid game-bento-grid-side" aria-label="Jeux Playgama similaires">
        {leftGames.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={`/games/${game.slug}/`}>
            <img src={game.thumbnail} alt={`Miniature ${game.title}`} width="640" height="360" loading={index === 0 ? "eager" : "lazy"} />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>

      <div class="embedded-game-frame">
        <iframe src={mainGame.localGamePath} title={mainGame.name} loading="eager" allow="autoplay; fullscreen *" allowfullscreen></iframe>
      </div>

      <div class="game-bento-grid game-bento-grid-side" aria-label="Autres jeux Playgama similaires">
        {rightGames.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={`/games/${game.slug}/`}>
            <img src={game.thumbnail} alt={`Miniature ${game.title}`} width="640" height="360" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
    </div>

    <section class="game-guide-section" aria-labelledby="play-guide-title">
      <aside class="game-guide-aside" aria-label="Navigation du guide Royal Match">
        <p>Guide Royal Match</p>
        {guideItems.map((item, index) => (
          <a href={`#${item.id}`}><span>{String(index + 1).padStart(2, "0")}</span>{item.label}</a>
        ))}
      </aside>

      <div class="game-guide-main">
        <header class="game-guide-head">
          <h2 id="play-guide-title">Associez les joyaux sans gaspiller vos coups.</h2>
          <p>Les cartes autour du lecteur mènent vers de vrais jeux Playgama similaires quand vous voulez varier après une partie.</p>
        </header>
        <div class="game-guide-flow">
          {guideItems.map((item, index) => (
            <article class="game-guide-block" id={item.id}>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
