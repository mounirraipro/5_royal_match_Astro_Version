---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { externalGames } from "@/data/externalGames";
import { mainGame } from "@/data/mainGame";

const leftGames = externalGames.slice(0, 4);
const rightGames = externalGames.slice(4, 8);
const guideItems = [
  {
    id: "royal-match-rules",
    label: "Regles",
    title: "Alignez trois joyaux",
    body: "Echangez deux pieces voisines pour creer une ligne ou une colonne de trois joyaux identiques. Les coups utiles rapprochent toujours l'objectif du niveau.",
  },
  {
    id: "royal-match-bonus",
    label: "Boosters",
    title: "Preparez les gros coups",
    body: "Les associations de quatre ou cinq pieces donnent des boosters comme la fusee, la TNT, l'helice ou la boule lumineuse selon la logique du match-3.",
  },
  {
    id: "royal-match-mobile",
    label: "Mobile",
    title: "Jouez avec des gestes courts",
    body: "Sur telephone, utilisez des mouvements precis et attendez la fin des animations avant de choisir le coup suivant.",
  },
  {
    id: "royal-match-disclaimer",
    label: "Info",
    title: "Site independant",
    body: "royalmatch.fr n'est pas le site officiel de Dream Games. Le lecteur propose une experience Playgama similaire pour jouer vite dans le navigateur.",
  },
];
---

<BaseLayout
  title={`Jouer a ${mainGame.name}`}
  description="Jouez a Royal Match en ligne gratuitement, sans telechargement, avec une experience Playgama similaire, des jeux comme Royal Match et des astuces match-3."
>
  <section class="embedded-game-page accent-blue">
    <header class="embedded-game-head">
      <nav class="crumbs"><a href="/">Accueil</a><span>/</span><span>Jouer</span></nav>
      <h1>Jouer a Royal Match en ligne gratuitement.</h1>
      <p>Ouvrez une experience match-3 royale directement dans le navigateur, sans telechargement. royalmatch.fr est un site independant: Royal Match est une marque de Dream Games et le jeu integre peut etre une experience Playgama similaire.</p>
    </header>

    <div class="embedded-game-layout">
      <div class="game-bento-grid game-bento-grid-side" aria-label="Jeux Playgama similaires">
        {leftGames.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={`/games/${game.slug}/`}>
            <img src={game.thumbnail} alt={`Miniature ${game.title}`} width="640" height="360" loading={index === 0 ? "eager" : "lazy"} />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>

      <div class="embedded-game-frame">
        <iframe src={mainGame.localGamePath} title={mainGame.name} loading="eager" allow="autoplay; fullscreen *" allowfullscreen></iframe>
      </div>

      <div class="game-bento-grid game-bento-grid-side" aria-label="Autres jeux Playgama similaires">
        {rightGames.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={`/games/${game.slug}/`}>
            <img src={game.thumbnail} alt={`Miniature ${game.title}`} width="640" height="360" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
    </div>

    <section class="game-guide-section" aria-labelledby="play-guide-title">
      <aside class="game-guide-aside" aria-label="Navigation du guide Royal Match">
        <p>Guide Royal Match</p>
        {guideItems.map((item, index) => (
          <a href={`#${item.id}`}><span>{String(index + 1).padStart(2, "0")}</span>{item.label}</a>
        ))}
      </aside>

      <div class="game-guide-main">
        <header class="game-guide-head">
          <h2 id="play-guide-title">Associez les joyaux sans gaspiller vos coups.</h2>
          <p>Les cartes autour du lecteur menent vers de vrais jeux Playgama similaires quand vous voulez varier apres une partie. Pour progresser, lisez d'abord l'objectif, creez des boosters, puis combinez-les dans les zones bloquees.</p>
        </header>
        <div class="game-guide-flow">
          {guideItems.map((item, index) => (
            <article class="game-guide-block" id={item.id}>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
