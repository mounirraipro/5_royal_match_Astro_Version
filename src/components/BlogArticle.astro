---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { type Article } from "@/data/articles";
import { siteConfig } from "@/data/siteConfig";

type Props = {
  article: Article;
};

const { article } = Astro.props;
---

<BaseLayout
  title={article.title}
  description={article.description}
  seo={{
    path: `/blog/${article.slug}`,
    seoTitle: `${article.title} | ${siteConfig.name}`,
    keywords: article.keywords,
    schemaType: "Article",
    datePublished: article.datePublished,
    updated: article.dateModified,
  }}
>
  <article class="content-page">
    <header class="page-header">
      <div class="page-header-inner">
        <p class="eyebrow">{article.category}</p>
        <h1>{article.title}</h1>
        <p>{article.description}</p>
      </div>
    </header>

    <div class="content-page-shell">
      <div class="page-content">
        <p><strong>{article.readTime}</strong> - Mis a jour le {article.dateModified}</p>
        <Fragment set:html={article.html} />
      </div>
      <aside class="content-page-aside" aria-label="Liens de l'article">
        <p>Continuer</p>
        <nav>
          <a class="content-page-link" href="/play/">Jouer a Royal Match</a>
          <a class="content-page-link" href="/games/">Jeux similaires</a>
          <a class="content-page-link" href="/how-to-play/">Comment jouer</a>
          <a class="content-page-link" href="/blog/">Plus de guides</a>
        </nav>
      </aside>
    </div>
  </article>
</BaseLayout>
